# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/rural-art-platform
# 生产环境使用:
# MONGODB_URI=mongodb://admin:password123@mongodb:27017/rural-art-platform?authSource=admin

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 广州大学智能体平台配置
GZHU_AGENT_API_URL=https://api.gzhu.edu.cn/agent
GZHU_AGENT_KEY=your-gzhu-agent-key

# Coze智能体服务配置
COZE_API_URL=https://api.coze.com/v1
COZE_API_KEY=your-coze-api-key
COZE_IMAGE_ENHANCE_BOT_ID=your-image-enhance-bot-id
COZE_STYLE_TRANSFER_BOT_ID=your-style-transfer-bot-id
COZE_PATTERN_GENERATE_BOT_ID=your-pattern-generate-bot-id
COZE_SMART_REPAIR_BOT_ID=your-smart-repair-bot-id

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info

# 邮件服务配置（可选）
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-email-password
# EMAIL_FROM=noreply@rural-art-platform.com

# Redis配置（可选，用于缓存和会话）
# REDIS_URL=redis://localhost:6379

# 第三方服务配置
# 阿里云OSS（可选，用于文件存储）
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# ALIYUN_OSS_BUCKET=your-bucket-name

# 微信小程序配置（可选）
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret

# 支付配置（可选）
# WECHAT_PAY_MCH_ID=your-merchant-id
# WECHAT_PAY_KEY=your-pay-key
# ALIPAY_APP_ID=your-alipay-app-id
# ALIPAY_PRIVATE_KEY=your-alipay-private-key